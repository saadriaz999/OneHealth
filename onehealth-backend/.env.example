# Must match docker-compose db credentials when using Compose Postgres
POSTGRES_USER=onehealth
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=onehealth_db

DATABASE_URL=postgresql://onehealth:yourpassword@127.0.0.1:5432/onehealth_db
SECRET_KEY=your-super-secret-jwt-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

ANTHROPIC_API_KEY=your-anthropic-api-key
DRUGBANK_API_KEY=your-drugbank-api-key
